# env-doctor configuration example
# Copy this file to .env-doctor.conf in your repository root to customize env-doctor.

# BRAND: Custom banner title displayed at the top of the output (default: script name)
# BRAND="My Project"

# ENV_DOCTOR_CORE_REPOS: A regular expression matching path suffixes of submodules
# that are considered "core" and should be initialized in Tier 1.
# ENV_DOCTOR_CORE_REPOS="my-core-library|shared-types"

# ENV_DOCTOR_PYTHON_DEPS: Comma-separated list of Python packages to verify
# (by trying to import them) when a Python project is detected.
# ENV_DOCTOR_PYTHON_DEPS="yaml,click,pydantic,requests"

# ENV_DOCTOR_HELP_URL: Custom URL printed next to private submodule warnings
# to guide developers on how to set up access (e.g., SSH keys, tokens).
# ENV_DOCTOR_HELP_URL="https://github.com/my-org/my-project/wiki/Access-Setup"
